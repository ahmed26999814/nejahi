    "assets": "python3 scripts/generate_assets.py"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "57.0.4",
    "expo-haptics": "57.0.0",
    "expo-linear-gradient": "57.0.0",
    "expo-network": "57.0.0",
    "expo-notifications": "57.0.3",
    "expo-print": "57.0.0",
    "expo-sharing": "57.0.3",
    "expo-status-bar": "57.0.0",
    "expo-system-ui": "57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "5.7.0"
  },
  "devDependencies": {
    "@types/react": "19.2.2",
    "typescript": "5.9.2"
  }
}
